<% raw_ai_settings = @settings || {} %>
<% normalized_ai_settings = {} %>
<% raw_ai_settings.each { |key, value| normalized_ai_settings[key.to_s] = value } if raw_ai_settings.respond_to?(:each) %>
<% ai_settings = RedminePluginCheck::AiSettings::DEFAULTS.merge(normalized_ai_settings) %>
<% ai_settings_object = RedminePluginCheck::AiSettings.new(ai_settings) %>
<% ai_provider_presets = RedminePluginCheck::AiSettings::PROVIDER_PRESETS %>
<% ai_api_key_values = {} %>
<% ai_api_key_field_ids = {} %>
<% ai_provider_presets.keys.each do |preset_key| %>
  <% setting_key = RedminePluginCheck::AiSettings.api_key_setting_key(preset_key) %>
  <% saved_value = ai_settings[setting_key].to_s %>
  <% saved_value = ai_settings['ai_api_key'].to_s if saved_value.blank? && preset_key == ai_settings_object.provider_preset %>
  <% ai_api_key_values[preset_key] = saved_value %>
  <% ai_api_key_field_ids[preset_key] = "settings_#{setting_key}" %>
<% end %>


<p>
  <label><%= l(:label_ai_analysis_enabled) %></label>
  <%= hidden_field_tag 'settings[ai_enabled]', '0' %>
  <%= check_box_tag 'settings[ai_enabled]', '1', ai_settings['ai_enabled'].to_s == '1' %>
</p>

<p>
  <label><%= l(:label_ai_provider_preset) %></label>
  <%= select_tag 'settings[ai_provider_preset]', options_for_select(RedminePluginCheck::AiSettings.provider_preset_options, ai_settings_object.provider_preset), :id => 'settings_ai_provider_preset' %>
  <%= link_to l(:button_ai_test_connection),
              plugin_check_ai_test_connection_path,
              :class => 'icon icon-checked',
              :id => 'settings_ai_test_connection' %>
  <span class="plugin-check-ai-progress" id="settings_ai_test_connection_progress" style="display:none;">
    <span class="plugin-check-ai-spinner"></span>
    <span><%= l(:text_ai_test_connection_connecting) %></span>
  </span>
  <em class="info"><%= l(:text_ai_test_connection_saved_settings) %></em>
</p>

<p>
  <label><%= l(:label_ai_provider_label) %></label>
  <%= text_field_tag 'settings[ai_provider_label]', ai_settings['ai_provider_label'], :size => 40, :id => 'settings_ai_provider_label' %>
</p>

<p>
  <label><%= l(:label_ai_endpoint) %></label>
  <%= text_field_tag 'settings[ai_endpoint]', ai_settings['ai_endpoint'], :size => 80, :id => 'settings_ai_endpoint' %>
</p>

<p>
  <label><%= l(:label_ai_api_key_env) %></label>
  <%= text_field_tag 'settings[ai_api_key_env]', ai_settings['ai_api_key_env'], :size => 40, :id => 'settings_ai_api_key_env' %>
</p>

<p>
  <label><%= l(:label_ai_api_key) %></label>
  <% ai_api_key_values.each do |preset_key, api_key_value| %>
    <%= hidden_field_tag "settings[#{RedminePluginCheck::AiSettings.api_key_setting_key(preset_key)}]", api_key_value, :id => ai_api_key_field_ids[preset_key] %>
  <% end %>
  <%= hidden_field_tag 'settings[ai_api_key]', ai_settings['ai_api_key'] %>
  <%= password_field_tag 'settings_ai_api_key_visible', ai_api_key_values[ai_settings_object.provider_preset], :size => 80, :autocomplete => 'off', :id => 'settings_ai_api_key' %>
  <em class="info"><%= l(:text_ai_api_key_env_preferred) %></em>
</p>

<p>
  <label><%= l(:label_ai_model) %></label>
  <%= text_field_tag 'settings[ai_model]', ai_settings['ai_model'], :size => 40, :id => 'settings_ai_model' %>
  <%= button_tag l(:button_ai_fetch_gemini_models), :type => 'button', :id => 'settings_ai_fetch_gemini_models', :class => 'icon icon-reload' %>
  <%= select_tag 'settings_ai_gemini_model_select', '', :id => 'settings_ai_gemini_model_select', :style => 'display:none' %>
  <em class="info" id="settings_ai_gemini_model_status"></em>
  <em class="info" id="settings_ai_gemini_model_note"><%= l(:text_ai_fetch_gemini_models_saved_settings_required) %></em>
</p>

<p>
  <label><%= l(:label_ai_timeout_seconds) %></label>
  <%= text_field_tag 'settings[ai_timeout_seconds]', ai_settings['ai_timeout_seconds'], :size => 8 %>
</p>

<p>
  <label><%= l(:label_ai_max_prompt_characters) %></label>
  <%= text_field_tag 'settings[ai_max_prompt_characters]', ai_settings['ai_max_prompt_characters'], :size => 12 %>
</p>

<p>
  <label><%= l(:label_ai_system_prompt) %></label>
  <%= text_area_tag 'settings[ai_system_prompt]', ai_settings_object.system_prompt, :cols => 80, :rows => 6 %>
</p>
<script type="text/javascript">
//<![CDATA[
(function() {
  var presets = <%= raw ai_provider_presets.to_json %>;
  var apiKeyValues = <%= raw ai_api_key_values.to_json %>;
  var apiKeyFieldIds = <%= raw ai_api_key_field_ids.to_json %>;
  var select = document.getElementById('settings_ai_provider_preset');
  var fetchGeminiModels = document.getElementById('settings_ai_fetch_gemini_models');
  var geminiModelSelect = document.getElementById('settings_ai_gemini_model_select');
  var geminiModelStatus = document.getElementById('settings_ai_gemini_model_status');
  var geminiModelNote = document.getElementById('settings_ai_gemini_model_note');
  var apiKeyField = document.getElementById('settings_ai_api_key');
  var currentPreset = select ? select.value : null;
  var testConnection = document.getElementById('settings_ai_test_connection');
  var testConnectionProgress = document.getElementById('settings_ai_test_connection_progress');
  if (!select) { return; }

  function setValue(id, value) {
    var field = document.getElementById(id);
    if (field) { field.value = value || ''; }
  }

  function geminiEndpoint(model) {
    return 'https://generativelanguage.googleapis.com/v1beta/models/' + encodeURIComponent(model) + ':generateContent';
  }

  function saveCurrentApiKey() {
  if (!apiKeyField || !currentPreset) { return; }
  apiKeyValues[currentPreset] = apiKeyField.value;
  var hidden = document.getElementById(apiKeyFieldIds[currentPreset]);
  if (hidden) { hidden.value = apiKeyField.value; }
}

  function loadApiKeyForPreset(preset) {
  if (apiKeyField) { apiKeyField.value = apiKeyValues[preset] || ''; }
}

  function updateGeminiControls() {
  var isGemini = select && select.value === 'gemini';
  if (fetchGeminiModels) { fetchGeminiModels.style.display = isGemini ? '' : 'none'; }
  if (geminiModelNote) { geminiModelNote.style.display = isGemini ? '' : 'none'; }
  if (!isGemini && geminiModelSelect) { geminiModelSelect.style.display = 'none'; }
  if (!isGemini && geminiModelStatus) { geminiModelStatus.innerHTML = ''; }
}

  select.onchange = function() {
  saveCurrentApiKey();
  currentPreset = select.value;
  loadApiKeyForPreset(currentPreset);

  var preset = presets[select.value];
  if (!preset || select.value === 'custom') {
    updateGeminiControls();
    return;
  }

  setValue('settings_ai_provider_label', preset.provider_label);
  setValue('settings_ai_endpoint', preset.endpoint);
  setValue('settings_ai_api_key_env', preset.api_key_env);
  setValue('settings_ai_model', preset.model);
  if (select.value === 'gemini') { setValue('settings_ai_endpoint', geminiEndpoint(preset.model)); }
  updateGeminiControls();
};

  if (apiKeyField && apiKeyField.form) {
  apiKeyField.form.onsubmit = function() {
    saveCurrentApiKey();
    return true;
  };
}


  if (fetchGeminiModels) {
    fetchGeminiModels.onclick = function() {
      if (!geminiModelStatus || !geminiModelSelect) { return; }
      geminiModelStatus.innerHTML = '<%= j l(:text_ai_fetching_gemini_models) %>';
      fetch('<%= plugin_check_gemini_models_path %>', { credentials: 'same-origin' })
        .then(function(response) { return response.json().then(function(data) { return { ok: response.ok, data: data }; }); })
        .then(function(result) {
          if (!result.ok || !result.data.success) { throw new Error(result.data.message || '<%= j l(:text_ai_gemini_models_fetch_failed) %>'); }
          geminiModelSelect.innerHTML = '';
          result.data.models.forEach(function(model) {
            var option = document.createElement('option');
            option.value = model;
            option.text = model;
            geminiModelSelect.appendChild(option);
          });
          geminiModelSelect.style.display = '';
          geminiModelStatus.innerHTML = '<%= j l(:text_ai_select_gemini_model) %>';
        })
        .catch(function(error) {
          geminiModelSelect.style.display = 'none';
          geminiModelStatus.innerHTML = error.message;
        });
    };
  }

  if (geminiModelSelect) {
    geminiModelSelect.onchange = function() {
      setValue('settings_ai_model', geminiModelSelect.value);
      setValue('settings_ai_endpoint', geminiEndpoint(geminiModelSelect.value));
    };
  }

  if (testConnection) {
    testConnection.onclick = function() {
      if (testConnectionProgress) { testConnectionProgress.style.display = 'inline-flex'; }
      testConnection.className = testConnection.className + ' disabled';
      testConnection.innerHTML = '<%= j l(:text_ai_test_connection_connecting) %>';
      return true;
    };
  }

  updateGeminiControls();
}());
//]]>
</script>

<p class="plugin-check-settings-footer-link" id="plugin-check-settings-footer-link">
  <%= link_to l(:label_back_to_plugin_check), plugin_check_path, :class => 'plugin-check-settings-button' %>
</p>

<script type="text/javascript">
//<![CDATA[
(function() {
  function movePluginCheckFooterLink() {
    var footer = document.getElementById('plugin-check-settings-footer-link');
    if (!footer) { return; }

    var node = footer;
    while (node && node.tagName && node.tagName.toLowerCase() !== 'form') {
      node = node.parentNode;
    }
    if (!node) { return; }

    var inputs = node.getElementsByTagName('input');
    for (var i = 0; i < inputs.length; i++) {
      if (inputs[i].type === 'submit') {
        inputs[i].parentNode.insertBefore(footer, inputs[i].nextSibling);
        break;
      }
    }
  }

  if (window.addEventListener) {
    window.addEventListener('load', movePluginCheckFooterLink, false);
  } else if (window.attachEvent) {
    window.attachEvent('onload', movePluginCheckFooterLink);
  }
}());
//]]>
</script>
