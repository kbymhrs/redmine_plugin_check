<% html_title l(:label_redmine_upgrade_advisor) %>
<% content_for :header_tags do %>
  <%= stylesheet_link_tag 'redmine_upgrade_advisor', :plugin => 'redmine_plugin_check' %>
<% end %>

<h2><%= l(:label_redmine_upgrade_advisor) %></h2>

<p class="upgrade-advisor-intro"><%= l(:text_redmine_upgrade_advisor_intro) %></p>

<div class="upgrade-advisor-summary">
  <div>
    <strong><%= l(:label_current_redmine_version) %></strong>
    <%= @report.redmine_version %>
  </div>
  <div>
    <strong><%= l(:label_current_ruby_version) %></strong>
    <%= @report.ruby_version %>
  </div>
  <div>
    <strong><%= l(:label_current_rails_version) %></strong>
    <%= @report.rails_version %>
  </div>
  <div>
    <strong><%= l(:label_target_redmine_version) %></strong>
    <%= @report.target_version.presence || '-' %>
  </div>
</div>

<%= form_tag plugin_check_path, :method => :get, :class => 'upgrade-advisor-form' do %>
  <p>
    <%= label_tag :target_version, l(:label_target_redmine_version) %>
    <%= text_field_tag :target_version, @target_version, :size => 16, :placeholder => '6.0.0' %>
    <span class="upgrade-advisor-form-option">
      <%= check_box_tag :check_latest, '1', @check_latest %>
      <%= label_tag :check_latest, l(:label_check_latest_version) %>
    </span>
    <%= submit_tag l(:button_apply), :name => nil %>
    <% csv_params = { :target_version => @target_version, :format => :csv } %>
    <% csv_params[:check_latest] = '1' if @check_latest %>
    <%= link_to l(:label_export_csv),
                plugin_check_path(csv_params),
                :class => 'icon icon-save' %>
  </p>
<% end %>

<div class="autoscroll upgrade-advisor-table-shell">
  <table class="list upgrade-advisor-plugins">
    <colgroup>
      <col class="upgrade-advisor-status-col" />
      <col class="upgrade-advisor-id-col" />
      <col class="upgrade-advisor-name-col" />
      <col class="upgrade-advisor-version-col" />
      <col class="upgrade-advisor-latest-version-col" />
      <col class="upgrade-advisor-author-col" />
      <col class="upgrade-advisor-date-col" />
      <col class="upgrade-advisor-requires-col" />
      <col class="upgrade-advisor-flag-col" />
      <col class="upgrade-advisor-flag-col" />
      <col class="upgrade-advisor-flag-col" />
      <col class="upgrade-advisor-flag-col" />
      <col class="upgrade-advisor-flag-col" />
      <col class="upgrade-advisor-findings-col" />
      <col class="upgrade-advisor-notes-col" />
    </colgroup>
    <thead>
      <tr>
        <th><%= upgrade_advisor_column_header(:field_status, :status) %></th>
        <th><%= upgrade_advisor_column_header(:field_identifier, :identifier) %></th>
        <th><%= upgrade_advisor_column_header(:field_name, :name) %></th>
        <th><%= upgrade_advisor_column_header(:field_version, :version) %></th>
        <th><%= upgrade_advisor_column_header(:label_latest_version, :latest_version) %></th>
        <th><%= upgrade_advisor_column_header(:field_author, :author) %></th>
        <th><%= upgrade_advisor_column_header(:label_last_modified_at, :last_modified_at) %></th>
        <th><%= upgrade_advisor_column_header(:label_requires_redmine, :requires_redmine) %></th>
        <th><%= upgrade_advisor_column_header(:label_requires_redmine_lower_bound_only, :requires_redmine_lower_bound_only) %></th>
        <th><%= upgrade_advisor_column_header(:label_target_major_jump, :target_major_jump) %></th>
        <th><%= upgrade_advisor_column_header(:label_redmine_condition_in_init, :redmine_condition_in_init) %></th>
        <th><%= upgrade_advisor_column_header(:label_has_migrations, :has_migrations) %></th>
        <th><%= upgrade_advisor_column_header(:label_has_gemfile, :has_gemfile) %></th>
        <th><%= upgrade_advisor_column_header(:label_compatibility_findings, :compatibility_findings) %></th>
        <th class="upgrade-advisor-notes-column"><%= upgrade_advisor_column_header(:label_notes, :notes) %></th>
      </tr>
    </thead>
    <tbody>
      <% @report.plugins.each do |plugin| %>
        <tr>
          <td><%= upgrade_advisor_status_label(plugin.status) %></td>
          <td><code><%= plugin.id %></code></td>
          <td><%= plugin.name.presence || '-' %></td>
          <td><%= plugin.version.presence || '-' %></td>
          <td><%= upgrade_advisor_latest_version_label(plugin, @check_latest) %></td>
          <td><%= plugin.author.presence || '-' %></td>
          <td><%= plugin.last_modified_at ? format_time(plugin.last_modified_at) : '-' %></td>
          <td><%= upgrade_advisor_requires_label(plugin) %></td>
          <td><%= upgrade_advisor_boolean_label(plugin.requires_redmine_lower_bound_only) %></td>
          <td><%= upgrade_advisor_boolean_label(plugin.target_major_jump) %></td>
          <td><%= upgrade_advisor_boolean_label(plugin.redmine_condition_in_init) %></td>
          <td><%= upgrade_advisor_boolean_label(plugin.has_migrations) %></td>
          <td><%= upgrade_advisor_boolean_label(plugin.has_gemfile) %></td>
          <td>
            <% if plugin.compatibility_findings.any? %>
              <ul class="upgrade-advisor-findings">
                <% plugin.compatibility_findings.each do |finding| %>
                  <li><%= upgrade_advisor_finding_label(finding) %></li>
                <% end %>
              </ul>
            <% else %>
              -
            <% end %>
          </td>
          <td class="upgrade-advisor-notes-column">
            <% if plugin.notes.any? %>
              <ul class="upgrade-advisor-notes">
                <% plugin.notes.each do |note| %>
                  <li><%= upgrade_advisor_note_label(note) %></li>
                <% end %>
              </ul>
            <% else %>
              -
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<div class="upgrade-advisor-help">
  <h3><%= l(:label_upgrade_advisor_column_help) %></h3>
  <table class="upgrade-advisor-help-table">
    <thead>
      <tr>
        <th class="upgrade-advisor-help-cell"><%= l(:label_upgrade_advisor_help_column_name) %></th>
        <th class="upgrade-advisor-help-cell"><%= l(:label_upgrade_advisor_help_column_description) %></th>
      </tr>
    </thead>
    <tbody>
      <% upgrade_advisor_column_help_items.each do |label_key, help_key| %>
        <tr>
          <th class="upgrade-advisor-help-cell"><%= l(label_key) %></th>
          <td class="upgrade-advisor-help-cell"><%= upgrade_advisor_column_help_text(help_key) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
