<% html_title l(:label_plugin_compatibility_check) %>
<% content_for :header_tags do %>
  <%= stylesheet_link_tag 'redmine_plugin_check', :plugin => 'redmine_plugin_check' %>
<% end %>

<h2><%= l(:label_plugin_compatibility_check) %></h2>

<p class="plugin-check-intro"><%= l(:text_redmine_plugin_check_intro) %></p>

<div class="plugin-check-summary">
  <div>
    <strong><%= l(:label_current_redmine_version) %></strong>
    <%= @report.redmine_version %>
  </div>
  <div>
    <strong><%= l(:label_current_ruby_version) %></strong>
    <%= @report.ruby_version %>
  </div>
  <div>
    <strong><%= l(:label_current_rails_version) %></strong>
    <%= @report.rails_version %>
  </div>
  <div>
    <strong><%= l(:label_target_redmine_version) %></strong>
    <%= @report.target_version.presence || '-' %>
  </div>
</div>

<%= form_tag plugin_check_path, :method => :get, :class => 'plugin-check-form' do %>
  <p>
    <%= label_tag :target_version, l(:label_target_redmine_version) %>
    <%= text_field_tag :target_version, @target_version, :size => 16, :placeholder => '6.0.0' %>
    <span class="plugin-check-form-option">
      <%= label_tag :status_filter, l(:label_status_filter) %>
      <%= select_tag :status_filter, options_for_select(plugin_check_status_filter_options, @status_filter) %>
    </span>
    <span class="plugin-check-form-option">
      <%= check_box_tag :check_latest, '1', @check_latest %>
      <%= label_tag :check_latest, l(:label_check_latest_version) %>
    </span>
    <span class="plugin-check-form-option">
      <%= check_box_tag :show_details, '1', @show_details %>
      <%= label_tag :show_details, l(:label_show_detail_columns) %>
    </span>
    <%= submit_tag l(:button_apply), :name => nil %>
    <% csv_params = { :target_version => @target_version, :status_filter => @status_filter, :format => :csv } %>
    <% csv_params[:check_latest] = '1' if @check_latest %>
    <% csv_params[:show_details] = '1' if @show_details %>
    <%= link_to l(:label_export_csv),
                plugin_check_path(csv_params),
                :class => 'icon icon-save' %>
    <% ai_markdown_params = { :target_version => @target_version, :status_filter => @status_filter } %>
    <% ai_markdown_params[:check_latest] = '1' if @check_latest %>
    <% ai_markdown_params[:show_details] = '1' if @show_details %>
    <%= link_to l(:label_export_ai_markdown),
                plugin_check_ai_markdown_path(ai_markdown_params),
                :class => 'icon icon-save' %>
  </p>
<% end %>

<div class="autoscroll plugin-check-table-shell<%= @plugins.size >= 5 ? ' plugin-check-table-shell-scroll' : '' %>">
  <table class="list plugin-check-plugins<%= @show_details ? ' plugin-check-plugins-detail' : ' plugin-check-plugins-summary' %>">
    <colgroup>
      <col class="plugin-check-status-col" />
      <col class="plugin-check-name-col" />
      <col class="plugin-check-id-col" />
      <col class="plugin-check-version-col" />
      <col class="plugin-check-latest-version-col" />
      <col class="plugin-check-author-col" />
      <col class="plugin-check-date-col" />
      <% if @show_details %>
        <col class="plugin-check-requires-col" />
        <col class="plugin-check-flag-col" />
        <col class="plugin-check-flag-col" />
        <col class="plugin-check-flag-col" />
        <col class="plugin-check-flag-col" />
        <col class="plugin-check-flag-col" />
        <col class="plugin-check-findings-col" />
      <% end %>
      <col class="plugin-check-primary-reasons-col" />
      <col class="plugin-check-notes-col" />
    </colgroup>
    <thead>
      <tr>
        <th><%= plugin_check_column_header(:field_status, :status) %></th>
        <th class="plugin-check-name-column"><%= plugin_check_column_header(:field_name, :name) %></th>
        <th class="plugin-check-id-column"><%= plugin_check_column_header(:field_identifier, :identifier) %></th>
        <th><%= plugin_check_column_header(:field_version, :version) %></th>
        <th><%= plugin_check_column_header(:label_latest_version, :latest_version) %></th>
        <th><%= plugin_check_column_header(:field_author, :author) %></th>
        <th><%= plugin_check_column_header(:label_last_modified_at, :last_modified_at) %></th>
        <% if @show_details %>
          <th><%= plugin_check_column_header(:label_requires_redmine, :requires_redmine) %></th>
          <th><%= plugin_check_column_header(:label_requires_redmine_lower_bound_only, :requires_redmine_lower_bound_only) %></th>
          <th><%= plugin_check_column_header(:label_target_major_jump, :target_major_jump) %></th>
          <th><%= plugin_check_column_header(:label_redmine_condition_in_init, :redmine_condition_in_init) %></th>
          <th><%= plugin_check_column_header(:label_has_migrations, :has_migrations) %></th>
          <th><%= plugin_check_column_header(:label_has_gemfile, :has_gemfile) %></th>
          <th class="plugin-check-findings-column"><%= plugin_check_column_header(:label_compatibility_findings, :compatibility_findings) %></th>
        <% end %>
        <th class="plugin-check-primary-reasons-column"><%= plugin_check_column_header(:label_primary_reasons, :primary_reasons) %></th>
        <th class="plugin-check-notes-column"><%= plugin_check_column_header(:label_notes, :notes) %></th>
      </tr>
    </thead>
    <tbody>
      <% @plugins.each do |plugin| %>
        <tr>
          <td><%= plugin_check_status_label(plugin.status) %></td>
          <td class="plugin-check-name-column"><%= plugin_check_name_label(plugin) %></td>
          <td class="plugin-check-id-column"><code><%= plugin.id %></code></td>
          <td><%= plugin.version.presence || '-' %></td>
          <td><%= plugin_check_latest_version_label(plugin, @check_latest) %></td>
          <td><%= plugin.author.presence || '-' %></td>
          <td><%= plugin.last_modified_at ? format_time(plugin.last_modified_at) : '-' %></td>
          <% if @show_details %>
            <td><%= plugin_check_requires_label(plugin) %></td>
            <td><%= plugin_check_boolean_label(plugin.requires_redmine_lower_bound_only) %></td>
            <td><%= plugin_check_boolean_label(plugin.target_major_jump) %></td>
            <td><%= plugin_check_boolean_label(plugin.redmine_condition_in_init) %></td>
            <td><%= plugin_check_boolean_label(plugin.has_migrations) %></td>
            <td><%= plugin_check_boolean_label(plugin.has_gemfile) %></td>
            <td class="plugin-check-findings-column">
              <% if plugin.compatibility_findings.any? %>
                <ul class="plugin-check-findings">
                  <% plugin.compatibility_findings.each do |finding| %>
                    <li class="<%= plugin_check_finding_class(finding) %>"><%= plugin_check_finding_label(finding) %></li>
                  <% end %>
                </ul>
              <% else %>
                -
              <% end %>
            </td>
          <% end %>
          <td class="plugin-check-primary-reasons-column"><%= plugin_check_reasons_label(plugin.primary_reasons) %></td>
          <td class="plugin-check-notes-column">
            <% if plugin.notes.any? %>
              <ul class="plugin-check-notes">
                <% plugin.notes.each do |note| %>
                  <li class="<%= plugin_check_note_class(note) %>"><%= plugin_check_note_label(note) %></li>
                <% end %>
              </ul>
            <% else %>
              -
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<div class="plugin-check-ai-panel">
  <% ai_analysis_content = nil %>
  <% ai_analysis_label = nil %>
  <% ai_analysis_saved_at = nil %>
  <% if @ai_analysis_result && @ai_analysis_result.success %>
    <% ai_analysis_content = @ai_analysis_result.content %>
    <% ai_analysis_label = l(:label_ai_analysis_result) %>
  <% elsif @latest_ai_analysis_content.present? %>
    <% ai_analysis_content = @latest_ai_analysis_content %>
    <% ai_analysis_label = l(:label_latest_ai_analysis_result) %>
    <% ai_analysis_saved_at = @latest_ai_analysis_generated_at %>
  <% end %>

  <h3><%= l(:label_ai_analysis) %></h3>
  <% if @target_version.blank? %>
    <p class="plugin-check-ai-unavailable"><%= l(:text_ai_analysis_target_version_required) %></p>
  <% elsif ai_analysis_content.blank? && plugin_check_ai_analysis_available?(@ai_settings) %>
    <%= form_tag plugin_check_ai_analysis_path, :method => :post, :class => 'plugin-check-ai-form', :id => 'plugin-check-ai-form' do %>
      <%= hidden_field_tag :target_version, @target_version %>
      <%= hidden_field_tag :status_filter, @status_filter %>
      <%= hidden_field_tag :check_latest, '1' if @check_latest %>
      <%= hidden_field_tag :show_details, '1' if @show_details %>
      <%= submit_tag l(:button_ai_analyze), :name => nil, :class => 'icon icon-checked', :id => 'plugin-check-ai-submit' %>
      <span class="plugin-check-ai-progress" id="plugin-check-ai-progress" style="display:none;">
        <span class="plugin-check-ai-spinner"></span>
        <span><%= l(:text_ai_analysis_connecting) %></span>
      </span>
    <% end %>
  <% elsif ai_analysis_content.blank? %>
    <p class="plugin-check-ai-unavailable">
      <%= plugin_check_ai_unavailable_message(@ai_settings) %>
      <%= link_to l(:label_plugin_check_settings),
                  plugin_settings_path(:id => 'redmine_plugin_check'),
                  :class => 'icon icon-settings plugin-check-settings-button' %>
    </p>
  <% end %>

  <% if @ai_analysis_target_version_missing %>
    <p class="plugin-check-ai-error"><%= l(:text_ai_analysis_target_version_required) %></p>
  <% end %>
  <% if ai_analysis_content.present? %>
    <div class="plugin-check-ai-result plugin-check-ai-markdown">
      <div class="plugin-check-ai-result-header">
        <h4><%= ai_analysis_label %></h4>
        <% if ai_analysis_saved_at.present? %>
          <span class="plugin-check-ai-saved-at"><%= l(:text_ai_analysis_saved_at, :value => format_time(ai_analysis_saved_at)) %></span>
        <% end %>
        <%= form_tag plugin_check_ai_analysis_download_path, :method => :post, :class => 'plugin-check-ai-download-form' do %>
          <%= text_area_tag :content, ai_analysis_content, :class => 'plugin-check-ai-download-content' %>
          <%= submit_tag l(:label_download_ai_analysis_result), :name => nil, :class => 'icon icon-save' %>
        <% end %>
        <% if @target_version.present? && plugin_check_ai_analysis_available?(@ai_settings) %>
          <%= form_tag plugin_check_ai_analysis_path, :method => :post, :class => 'plugin-check-ai-reanalyze-form' do %>
            <%= hidden_field_tag :target_version, @target_version %>
            <%= hidden_field_tag :status_filter, @status_filter %>
            <%= hidden_field_tag :check_latest, '1' if @check_latest %>
            <%= hidden_field_tag :show_details, '1' if @show_details %>
            <%= submit_tag l(:button_ai_reanalyze), :name => nil, :class => 'icon icon-reload plugin-check-ai-reanalyze-submit' %>
            <span class="plugin-check-ai-progress plugin-check-ai-reanalyze-progress" style="display:none;">
              <span class="plugin-check-ai-spinner"></span>
              <span><%= l(:text_ai_analysis_connecting) %></span>
            </span>
          <% end %>
        <% end %>
      </div>
      <div class="plugin-check-ai-preview">
        <%= plugin_check_markdown_preview(ai_analysis_content) %>
      </div>
    </div>
  <% elsif @ai_analysis_result %>
    <p class="plugin-check-ai-error"><%= plugin_check_ai_error_message(@ai_analysis_result) %></p>
  <% end %>
</div>

<div class="plugin-check-help">
  <h3><%= l(:label_plugin_check_column_help) %></h3>
  <table class="plugin-check-help-table">
    <thead>
      <tr>
        <th class="plugin-check-help-cell"><%= l(:label_plugin_check_help_column_name) %></th>
        <th class="plugin-check-help-cell"><%= l(:label_plugin_check_help_column_description) %></th>
      </tr>
    </thead>
    <tbody>
      <% plugin_check_column_help_items.each do |label_key, help_key| %>
        <tr>
          <th class="plugin-check-help-cell"><%= l(label_key) %></th>
          <td class="plugin-check-help-cell"><%= plugin_check_column_help_text(help_key) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
<script type="text/javascript">
//<![CDATA[
(function() {
  function showAiProgress(form, submit, progress) {
    if (progress) { progress.style.display = 'inline-flex'; }
    if (submit) {
      submit.disabled = true;
      submit.value = '<%= j l(:text_ai_analysis_connecting) %>';
    }
    return true;
  }

  var form = document.getElementById('plugin-check-ai-form');
  if (form) {
    form.onsubmit = function() {
      return showAiProgress(
        form,
        document.getElementById('plugin-check-ai-submit'),
        document.getElementById('plugin-check-ai-progress')
      );
    };
  }

  var reanalyzeForms = document.getElementsByClassName('plugin-check-ai-reanalyze-form');
  for (var i = 0; i < reanalyzeForms.length; i++) {
    reanalyzeForms[i].onsubmit = function() {
      return showAiProgress(
        this,
        this.getElementsByClassName('plugin-check-ai-reanalyze-submit')[0],
        this.getElementsByClassName('plugin-check-ai-reanalyze-progress')[0]
      );
    };
  }
})();
//]]>
</script>
